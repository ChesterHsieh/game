[gd_resource type="Resource" script_class="RecipeManifest" load_steps=4 format=3]

[ext_resource type="Script" path="res://src/data/recipe_manifest.gd" id="1_manifest"]
[ext_resource type="Script" path="res://src/data/recipe_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="RecipeEntry_generator_001"]
script = ExtResource("2_entry")
id = &"test_generator_001"
card_a = &"card_seed"
card_b = &"card_soil"
template = &"generator"
scene_id = &"global"
config = {"generates": &"card_sprout", "interval_sec": 3.0, "max_count": 5, "generator_card": &"card_seed"}

[resource]
script = ExtResource("1_manifest")
entries = [SubResource("RecipeEntry_generator_001")]
