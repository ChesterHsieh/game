[gd_resource type="Resource" script_class="RecipeManifest" load_steps=4 format=3]

[ext_resource type="Script" path="res://src/data/recipe_manifest.gd" id="1_manifest"]
[ext_resource type="Script" path="res://src/data/recipe_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="RecipeEntry_low_interval"]
script = ExtResource("2_entry")
id = &"low-interval-gen"
card_a = &"card-alpha"
card_b = &"card-beta"
template = &"generator"
scene_id = &"global"
config = {"generates": &"card-generates", "interval_sec": 0.1, "max_count": 5, "generator_card": &"card-alpha"}

[resource]
script = ExtResource("1_manifest")
entries = [SubResource("RecipeEntry_low_interval")]
