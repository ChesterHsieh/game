[gd_resource type="Resource" script_class="RecipeManifest" load_steps=6 format=3]

[ext_resource type="Script" path="res://src/data/recipe_manifest.gd" id="1_manifest"]
[ext_resource type="Script" path="res://src/data/recipe_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="RecipeEntry_fixture_001"]
script = ExtResource("2_entry")
id = &"fixture-additive-001"
card_a = &"fixture_card_a"
card_b = &"fixture_card_b"
template = &"additive"
scene_id = &"global"
config = {"spawns": [&"fixture_card_result"]}

[sub_resource type="Resource" id="RecipeEntry_fixture_002"]
script = ExtResource("2_entry")
id = &"fixture-merge-001"
card_a = &"fixture_card_c"
card_b = &"fixture_card_d"
template = &"merge"
scene_id = &"global"
config = {"result_card": &"fixture_card_merged"}

[sub_resource type="Resource" id="RecipeEntry_fixture_003"]
script = ExtResource("2_entry")
id = &"fixture-animate-001"
card_a = &"fixture_card_e"
card_b = &"fixture_card_f"
template = &"animate"
scene_id = &"global"
config = {"motion": &"float", "speed": 1.0, "target": &"fixture_card_target", "duration_sec": 1.5}

[resource]
script = ExtResource("1_manifest")
entries = [SubResource("RecipeEntry_fixture_001"), SubResource("RecipeEntry_fixture_002"), SubResource("RecipeEntry_fixture_003")]
